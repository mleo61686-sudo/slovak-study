generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  avatarUrl    String?
  passwordHash String
  createdAt    DateTime @default(now())

  resetTokens PasswordResetToken[]

  isPremium            Boolean   @default(false)
  premiumUntil         DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?

  // Email-нагадування
  emailRemindersEnabled    Boolean   @default(false)
  emailLanguage            String    @default("ua")
  preferredCourse          String    @default("sk")
  lastActiveAt             DateTime  @default(now())
  inactivityReminderSentAt DateTime?
  updatesEmailSentAt       DateTime?
  unsubscribeToken         String?   @unique

  // Зворотний зв’язок для прогресу
  progress     UserProgress?
  srsProgress  SrsProgress[]
  errorReports ErrorReport[]

  // Активності для leaderboard / рейтингу
  leaderboardActivities LeaderboardActivity[]
}

model UserProgress {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  lessonsProgress Json?
  updatedAt       DateTime @updatedAt

  lastUnlockedLevel String?
  dailyDate         DateTime?
  dailyCount        Int       @default(0)

  // Глобальний XP користувача між усіма курсами
  xp Int @default(0)
}

model PasswordResetToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Зберігаємо хеш токена, а не сам токен
  tokenHash String @unique

  expiresAt DateTime
  createdAt DateTime @default(now())

  // Позначка «використано»
  usedAt DateTime?
}

model ErrorReport {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Хто відправив, якщо користувач авторизований
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Контекст, де знайшли помилку
  page      String?
  lessonId  String?
  exercise  String?
  actionIdx Int?

  // Контент, про який повідомляють
  sk  String?
  ua  String?
  ru  String?
  key String?

  // Повідомлення користувача
  category String?
  status   String  @default("new")
  message  String

  // Технічна інформація
  userAgent String?
}

model TtsAudio {
  id        String   @id @default(cuid())
  key       String   @unique
  text      String
  url       String
  voice     String
  createdAt DateTime @default(now())
}

model SrsProgress {
  userId   String
  courseId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  data Json

  dailySession  Json?
  dailyNewWords Json?

  updatedAt DateTime @updatedAt

  @@id([userId, courseId])
  @@index([userId])
}

enum LeaderboardActivityType {
  LESSON
  REVIEW
  DICTATION
  AUDIO_QUIZ
}

model LeaderboardActivity {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        LeaderboardActivityType
  courseId    String
  activityKey String
  score       Int

  // Початок тижня. Для MVP використовуємо понеділок 00:00 UTC.
  weekStart DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Один урок / диктант / аудіоквіз за тиждень
  // не може нескінченно збільшувати рейтинг.
  // Під час повторного проходження зберігається найкращий score.
  @@unique([userId, type, courseId, activityKey, weekStart])
  @@index([weekStart])
  @@index([userId])
  @@index([type, weekStart])
  @@index([courseId, weekStart])
}
